# =============================================================================
# HEPTA ANALYTICS - ENVIRONMENT CONFIGURATION
# =============================================================================

# Database connection string (PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/hepta_analytics

# Node environment
NODE_ENV=development

# =============================================================================
# MULTI-TENANCY & API SECURITY
# =============================================================================

# Admin API key for tenant management operations
ADMIN_API_KEY=admin_your-secure-admin-key-here

# Cron job authentication
CRON_SECRET=your-cron-secret-here

# Intelligence API key (for batch processing endpoints)
INTELLIGENCE_API_KEY=your-intelligence-key-here

# =============================================================================
# ENRICHMENT PROVIDERS
# =============================================================================

# Clearbit (company enrichment from email domain)
CLEARBIT_API_KEY=sk_...

# AbstractAPI (company enrichment from IP)
ABSTRACTAPI_KEY=...

# =============================================================================
# SIGNAL DISPATCHERS
# =============================================================================

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=signals@yourdomain.com
RESEND_TO_EMAIL=sales@yourdomain.com

# =============================================================================
# INTEGRATIONS
# =============================================================================

# HubSpot (CRM sync) - OAuth tokens stored per-tenant in database
# HUBSPOT_APP_ID=...
# HUBSPOT_APP_SECRET=...

# Slack (notifications) - Webhook URLs stored per-tenant in database

# =============================================================================
# VECTOR EMBEDDINGS (Semantic Search)
# =============================================================================

# OpenAI API key for text-embedding-ada-002
# If not set, mock embeddings will be used
OPENAI_API_KEY=sk-...

# =============================================================================
# APPLICATION
# =============================================================================

# Public URL for email links and webhooks
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================

# FEATURE_ENRICHMENT=true
# FEATURE_INTEGRATIONS=true
# FEATURE_SEMANTIC_SEARCH=true
